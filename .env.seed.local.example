# ───────────────────────────────────────────────────────────────────────────
# Mallanet Cronner — entorno de desarrollo con datos simulados (sin Neon)
# Copiá a `.env.seed.local` y usá `pnpm dev:seed`
# ───────────────────────────────────────────────────────────────────────────

# Postgres local (docker compose up -d)
DATABASE_URL=postgresql://cronner:cronner@localhost:5433/cronner_seed

# Better Auth — cualquier secreto de 32+ caracteres para desarrollo local
BETTER_AUTH_SECRET=dev-seed-secret-minimo-32-caracteres!!
BETTER_AUTH_URL=http://localhost:3000

# OpenRouter (opcional; la app funciona sin IA)
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL_ID=anthropic/claude-3-haiku

# Indica modo demo con datos simulados (muestra credenciales en /login)
SEED_MODE=true
NEXT_PUBLIC_SEED_MODE=true
