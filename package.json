{
  "name": "mallanet-cronner",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project node",
    "test:watch": "vitest",
    "test:components": "vitest run --project components",
    "test:e2e": "playwright test",
    "test:e2e:prepare": "tsx scripts/e2e-prepare.mts",
    "test:all": "pnpm test && pnpm test:components && pnpm test:e2e",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm test:components",
    "db:schema": "tsx scripts/run-schema.mts",
    "db:migrate": "tsx scripts/migrate.mts",
    "db:tables": "tsx scripts/list-tables.mts",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:seed": "tsx scripts/seed.mts",
    "dev:seed": "tsx scripts/dev-seed.mts"
  },
  "dependencies": {
    "@ai-sdk/mistral": "^3.0.50",
    "@base-ui/react": "^1.5.0",
    "@openrouter/ai-sdk-provider": "^3.0.0",
    "@vercel/analytics": "1.6.1",
    "@vercel/functions": "^3.7.5",
    "ai": "^7.0.15",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "nanoid": "^5.1.16",
    "next": "16.2.6",
    "pg": "^8.22.0",
    "react": "^19",
    "react-dom": "^19",
    "react-markdown": "^10.1.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.8.0",
    "swr": "^2.4.2",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.5.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "jsdom": "^29.1.1",
    "postcss": "^8.5",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.23.0",
    "typescript": "5.7.3",
    "vitest": "^3.2.7"
  },
  "pnpm": {
    "overrides": {
      "hono": "4.12.25"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  }
