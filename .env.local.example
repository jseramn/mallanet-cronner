# ───────────────────────────────────────────────────────────────────────────
# Mallanet Cronner — variables de entorno para desarrollo local
# Copiá este archivo a `.env.local` y completá los valores.
# ───────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (Neon) ───────────────────────────────────────────────────────
# 1. Creá un proyecto en https://console.neon.tech (free tier)
# 2. En el dashboard del proyecto → Connection details → "Pooled connection"
# 3. Pegá acá el string (empieza con postgresql://)
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# ── Better Auth ─────────────────────────────────────────────────────────────
# Cualquier string aleatorio de al menos 32 caracteres.
# Podés generar uno con:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=poné_acá_un_string_aleatorio_de_32_caracteres_o_más

# URL base de la app (opcional; en local apunta a http://localhost:3000 por defecto).
BETTER_AUTH_URL=http://localhost:3000

# ── IA (slots + asistente) ──────────────────────────────────────────────────
# Provider: glm | mistral | openrouter. Si no se define, se elige por la key
# disponible (prioridad: GLM_API_KEY → MISTRAL_API_KEY → OPENROUTER_API_KEY).
AI_PROVIDER=glm

# Z.ai / GLM (https://z.ai/) — OpenAI-compatible
GLM_API_KEY=
GLM_MODEL_ID=glm-5.2
# GLM_BASE_URL=https://api.z.ai/api/coding/paas/v4/

# Mistral (https://console.mistral.ai/)
# AI_PROVIDER=mistral
# MISTRAL_API_KEY=
# MISTRAL_MODEL_ID=mistral-small-latest

# OpenRouter (opcional) — https://openrouter.ai/
# AI_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL_ID=anthropic/claude-3-haiku

# Asistente IA (opcional; override de modelo solo para el asistente)
# ASSISTANT_MODEL_ID=glm-5.2
# ASSISTANT_RATE_LIMIT_MAX=30
